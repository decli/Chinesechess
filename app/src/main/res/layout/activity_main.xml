<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5E6C8">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="中国象棋"
        android:textSize="48sp"
        android:textColor="#8B4513"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="经典国粹 · 智慧对弈"
        android:textSize="20sp"
        android:textColor="#A0522D"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartGame"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="人机对战"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#CC3333"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTwoPlayer"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="双人对战"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#1A6B1A"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDifficulty"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="难度：中级"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#CC8800"
            app:cornerRadius="12dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="280dp"
            android:layout_height="64dp"
            android:text="设置"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#555555"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="14sp"
        android:textColor="#999999"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
